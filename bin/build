#!/usr/bin/env bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"
cd "$DIR"

TARGET="${1:-debug}"
STATIC=false
shift 2>/dev/null || true
for arg in "$@"; do
	case "$arg" in
		--static) STATIC=true ;;
	esac
done
OUT_DIR=$DIR/build/$TARGET
mkdir -p $OUT_DIR

#
# Assets
#

rm -rf "$OUT_DIR/static"
cp -r "$DIR/static" "$OUT_DIR/"

mkdir -p "$OUT_DIR/static/scripts" "$OUT_DIR/static/styles"
cp "$DIR/vendor/datastar/datastar.js" "$OUT_DIR/static/scripts/"
cp "$DIR/vendor/datastar/datastar.js.map" "$OUT_DIR/static/scripts/"
cp "$DIR/vendor/modern-normalize.min.css" "$OUT_DIR/static/styles/"


PIECE_HASH=""

# Pieces: single combined hash for all SVGs
PIECE_DIR="$OUT_DIR/static/images/pieces"
if [ -d "$PIECE_DIR" ]; then
	PIECE_HASH=$(find "$PIECE_DIR" -name '*.svg' | sort | xargs cat | sha256sum | cut -c1-8)
	for f in "$PIECE_DIR"/*.svg; do
		base=$(basename "$f" .svg)
		mv "$f" "$PIECE_DIR/${base}-${PIECE_HASH}.svg"
	done
fi

# Hash and rename all non-piece, non-sourcemap static files
# Collect "odin_key original_path hashed_path" triples
DIGEST_ENTRIES=""
find "$OUT_DIR/static" -type f ! -name '*.map' ! -path '*/images/pieces/*' | sort | while read -r f; do
	rel="${f#$OUT_DIR/static/}"
	ext="${f##*.}"
	name_no_ext="${rel%.*}"
	hash=$(sha256sum "$f" | cut -c1-8)
	hashed="${name_no_ext}.${hash}.${ext}"
	mv "$f" "$OUT_DIR/static/$hashed"
	# Transform path to valid Odin identifier: / → __, . and - → _
	odin_key=$(echo "$rel" | sed 's|/|__|g; s|[.\-]|_|g')
	echo "$odin_key $rel $hashed"
done > "$DIR/digest_entries.tmp"

# Add piece_hash entry
if [ -n "$PIECE_HASH" ]; then
	echo "piece_hash _piece_hash $PIECE_HASH" >> "$DIR/digest_entries.tmp"
fi

$DIR/bin/codegen

#
# Build
#

FACILIO_DIR="$DIR/vendor/facil.io-0.7.6"
MUSTACHE4C_DIR="$DIR/vendor/mustache4c"

if [ "$TARGET" == "debug" ]; then
	CFLAGS="-g -O0"
else
	CFLAGS="-O2 -DNDEBUG -fno-asynchronous-unwind-tables"
fi

cc -c $CFLAGS \
	"$DIR/lib/facilio/wrapper.c" \
	-I "$FACILIO_DIR/libdump/include/" \
	-o "$OUT_DIR/wrapper.o"

cc -c $CFLAGS \
	"$DIR/lib/facilio/log_override.c" \
	-o "$OUT_DIR/log_override.o"

TMPDIR_AR=$(mktemp -d)
(cd "$TMPDIR_AR" && ar x "$FACILIO_DIR/libfacil.a")
ar rcs "$OUT_DIR/libfacilio_wrapper.a" \
	"$OUT_DIR/log_override.o" \
	"$OUT_DIR/wrapper.o" \
	"$TMPDIR_AR"/*.o
rm -rf "$TMPDIR_AR"

LDFLAGS="-L$OUT_DIR -L$MUSTACHE4C_DIR"

FLAGS="
	-out:"$OUT_DIR/$(basename $DIR)" \
	-collection:lib=lib \
	-disallow-do \
"

if [ $TARGET == "debug" ]; then
	FLAGS+="
		-debug \
		-define:USE_TRACKING_ALLOCATOR=true \
	"
else
	FLAGS+="
		-no-bounds-check \
		-o:speed \
		-vet-style -vet-semicolon -vet-cast -vet \
	"
	if [ "$STATIC" = true ]; then
		LDFLAGS+=" -static"
	else
		FLAGS+="-microarch:native "
	fi
fi

odin build src $FLAGS -extra-linker-flags:"$LDFLAGS"

#
# Mimir data files (NNUE weights + EGTB tables)
#

mkdir -p "$OUT_DIR/egtb"
cp "$DIR/mimir.nnue" "$OUT_DIR/mimir.nnue"
cp "$DIR/egtb/"*.bin "$OUT_DIR/egtb/"
