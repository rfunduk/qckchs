#!/usr/bin/env bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"
cd "$DIR"

TARGET="${1:-debug}"
STATIC=false
shift 2>/dev/null || true
for arg in "$@"; do
	case "$arg" in
		--static) STATIC=true ;;
	esac
done
OUT_DIR=$DIR/build/$TARGET
mkdir -p $OUT_DIR

#
# Assets
#

rm -rf "$OUT_DIR/static"
cp -r "$DIR/static" "$OUT_DIR/"

mkdir -p "$OUT_DIR/static/scripts" "$OUT_DIR/static/styles"
cp "$DIR/vendor/datastar/datastar.js" "$OUT_DIR/static/scripts/"
cp "$DIR/vendor/datastar/datastar.js.map" "$OUT_DIR/static/scripts/"
cp "$DIR/vendor/modern-normalize.min.css" "$OUT_DIR/static/styles/"

#
# Content hashing
#

DIGEST_TMP=$(mktemp)
PIECE_HASH=""

# Pieces: single combined hash for all SVGs
PIECE_DIR="$OUT_DIR/static/images/pieces"
if [ -d "$PIECE_DIR" ]; then
	PIECE_HASH=$(find "$PIECE_DIR" -name '*.svg' | sort | xargs cat | sha256sum | cut -c1-8)
	for f in "$PIECE_DIR"/*.svg; do
		base=$(basename "$f" .svg)
		mv "$f" "$PIECE_DIR/${base}-${PIECE_HASH}.svg"
		echo "images/pieces/${base}.svg images/pieces/${base}-${PIECE_HASH}.svg" >> "$DIGEST_TMP"
	done
fi

# Everything else: individual hash per file
find "$OUT_DIR/static" -type f ! -name '*.map' ! -path '*/images/pieces/*' | sort | while read -r f; do
	rel="${f#$OUT_DIR/static/}"
	ext="${f##*.}"
	name_no_ext="${rel%.*}"
	hash=$(sha256sum "$f" | cut -c1-8)
	hashed="${name_no_ext}.${hash}.${ext}"
	mv "$f" "$OUT_DIR/static/$hashed"
	echo "$rel $hashed" >> "$DIGEST_TMP"
done

# Build digest.json
{
	echo "{"
	first=true
	while IFS=' ' read -r orig hashed; do
		$first || printf ",\n"
		printf '  "%s": "%s"' "$orig" "$hashed"
		first=false
	done < "$DIGEST_TMP"
	if [ -n "$PIECE_HASH" ]; then
		$first || printf ",\n"
		printf '  "_piece_hash": "%s"' "$PIECE_HASH"
		first=false
	fi
	printf "\n}\n"
} > "$OUT_DIR/digest.json"

rm -f "$DIGEST_TMP"

#
# Template codegen — embed all .mustache files via #load
#

GEN="$DIR/src/templates_generated.odin"

cat > "$GEN" << 'HEADER'
// AUTO-GENERATED by bin/build - do not edit
package qckchs

load_template_strings :: proc() -> map[string]string {
	m := make(map[string]string)
HEADER

find "$DIR/templates" -name '*.mustache' -type f | sort | while read -r file; do
	rel="${file#$DIR/templates/}"
	key="${rel%.mustache}"
	printf '\tm["%s"] = string(#load("../templates/%s"))\n' "$key" "$rel" >> "$GEN"
done

cat >> "$GEN" << 'FOOTER'
	return m
}
FOOTER

#
# Build
#

FACILIO_DIR="$DIR/vendor/facil.io-0.7.6"

if [ "$TARGET" == "debug" ]; then
	CFLAGS="-g -O0"
else
	CFLAGS="-O2 -DNDEBUG -fno-asynchronous-unwind-tables"
fi

cc -c $CFLAGS \
	"$DIR/lib/facilio/wrapper.c" \
	-I "$FACILIO_DIR/libdump/include/" \
	-o "$OUT_DIR/wrapper.o"

cc -c $CFLAGS \
	"$DIR/lib/facilio/log_override.c" \
	-o "$OUT_DIR/log_override.o"

TMPDIR_AR=$(mktemp -d)
(cd "$TMPDIR_AR" && ar x "$FACILIO_DIR/libfacil.a")
ar rcs "$OUT_DIR/wrapper.a" \
	"$OUT_DIR/log_override.o" \
	"$OUT_DIR/wrapper.o" \
	"$TMPDIR_AR"/*.o
rm -rf "$TMPDIR_AR"

MUSTACHE4C_DIR="$DIR/vendor/mustache4c"

FLAGS="
	-define:FACILIO_WRAPPER_LIB=../../build/$TARGET/wrapper.a \
	-define:MUSTACHE4C_LIB=../../../vendor/mustache4c/libmustache4c.a \
	-out:"$OUT_DIR/$(basename $DIR)" \
	-collection:lib=lib \
	-disallow-do \
"

if [ $TARGET == "debug" ]; then
	FLAGS+="
		-debug \
		-define:USE_TRACKING_ALLOCATOR=true \
	"
else
	FLAGS+="
		-no-bounds-check \
		-o:speed \
		-vet-style -vet-semicolon -vet-cast -vet \
	"
	if [ "$STATIC" = true ]; then
		FLAGS+="-extra-linker-flags:\"-static\" "
	else
		FLAGS+="-microarch:native "
	fi
fi

odin build src $FLAGS

#
# Mimir data files (NNUE weights + EGTB tables)
#

mkdir -p "$OUT_DIR/egtb"
cp "$DIR/mimir.nnue" "$OUT_DIR/mimir.nnue"
cp "$DIR/egtb/"*.bin "$OUT_DIR/egtb/"
