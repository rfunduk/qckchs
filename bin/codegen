#!/usr/bin/env bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"
cd "$DIR"

#
# generate assets_generated.odin with struct, values, and template loader
#

GEN="$DIR/src/assets_generated.odin"

{
	cat << 'HEADER'
// AUTO-GENERATED by bin/build - do not edit
package qckchs

Asset_Paths :: struct {
HEADER

	# Struct fields (sorted by key)
	sort "$DIR/digest_entries.tmp" | while IFS=' ' read -r odin_key orig hashed; do
		printf '\t%s: string,\n' "$odin_key"
	done

	cat << 'MID1'
}

g_assets := Asset_Paths{
MID1

	# Struct values (sorted by key)
	sort "$DIR/digest_entries.tmp" | while IFS=' ' read -r odin_key orig hashed; do
		printf '\t%s = "%s",\n' "$odin_key" "$hashed"
	done

	cat << 'MID2'
}

load_template_strings :: proc() -> map[string]string {
	m := make(map[string]string)
MID2

	# Template #load entries
	find "$DIR/templates" -name '*.mustache' -type f | sort | while read -r file; do
		rel="${file#$DIR/templates/}"
		key="${rel%.mustache}"
		printf '\tm["%s"] = string(#load("../templates/%s"))\n' "$key" "$rel"
	done

	cat << 'FOOTER'
	return m
}
FOOTER
} > "$GEN"

rm -f "$DIR/digest_entries.tmp"
