#!/usr/bin/env bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd )"

TARGET="${1:-debug}"
OUT_DIR="$DIR/build/$TARGET"
MUSTACHE4C_DIR="$DIR/vendor/mustache4c"

FLAGS="
	-define:ODIN_TEST_THREADS=1 \
	-collection:lib=lib \
	-debug \
"

odin test tests/ $FLAGS -extra-linker-flags:"-L$OUT_DIR -L$MUSTACHE4C_DIR"
