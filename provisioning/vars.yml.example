app_name: "qckchs"
domain: "qckchs.com"
letsencrypt_email: ""

storage_host_path: "/var/lib/dokku/data/storage/{{ app_name }}"
storage_container_path: "/storage"
sqlite_db_path: "{{ storage_container_path }}/{{ app_name }}.db"
mimir_path: "{{ storage_container_path }}/mimir.json"

bots:
  easy: ""
  medium: ""
  hard: ""

# Litestream replica — Linode Object Storage
# litestream_version: "0.3.13"
# litestream_replica_url: "s3://your-bucket.us-east-1.linodeobjects.com/db"
# litestream_access_key_id: "YOUR_ACCESS_KEY"
# litestream_secret_access_key: "YOUR_SECRET_KEY"

authorized_keys:
  - "ssh-ed25519 XYZ123"

firewall_allowed_ports:
  - "22"
  - "80"
  - "443"
