{{> _header}}

{{#active}}
  <div data-init="@post('/stream/{{code}}', { retry: 'always' })"></div>
  <div data-on:make-move__window="@post(`/move/{{code}}/${evt.detail.from}/${evt.detail.to}`)"></div>
  <div data-on:flag__window="@get('/check/{{code}}')"></div>
  <div data-on-interval__3s="if ($state === 'waiting') @post('/ping/{{code}}')"></div>
{{/active}}

<div
  data-signals:turn="'{{turn}}'"
  data-signals:state="'{{state}}'"
  data-signals:white="{ name: '{{white.name}}', code: '{{white.code}}', periods: {{white.periods}} }"
  data-signals:black="{ name: '{{black.name}}', code: '{{black.code}}', periods: {{black.periods}} }"
  data-signals:result="'{{result}}'"
  data-signals:paired="{{paired}}"
  data-signals:public="{{public}}"
  data-signals:ply="{{max_ply}}"
  data-signals:max-ply="{{max_ply}}"
  data-signals:_color="'{{color}}'"
  data-signals:_status-dismissed="false"
  data-computed:_top-bar="'{{color}}' === 'white' ? $black : $white"
  data-computed:_bottom-bar="'{{color}}' === 'white' ? $white : $black"
  data-on:keydown__window="
    if (evt.key === 'ArrowLeft') @get(`/replay/{{code}}/${$ply - 1}`)
    if (evt.key === 'ArrowRight') @get(`/replay/{{code}}/${$ply + 1}`)
    if (evt.key === 'Escape') $_statusDismissed = true
  "
></div>

<div class="game-area">

  {{#join_prompt}}
    <div class="game-status" style="display: flex;">
      <p>Join this game?</p>
      <a class="button" href="/games/{{code}}?join=1">Join</a>
    </div>
  {{/join_prompt}}

  <div
    class="game-status"
    style="display: none;"
    data-class:waiting-for-players="$state == 'waiting'"
    data-show="($state === 'waiting' || ($state === 'resolved' && $ply === $maxPly)) && !$_statusDismissed"
  >
    <button
      class="dismiss-btn"
      style="display: none;"
      data-show="$state === 'resolved'"
      data-on:click__prevent="$_statusDismissed = true">&times;</button>
    <div class='variant' style="display: none;" data-show="$state === 'resolved'" data-text="$result"></div>
    <div class='variant' style="display: none;" data-show="$state === 'waiting' && !$paired">
      <p>Waiting for opponent...</p>
      <button
        class="button"
        data-on:click__prevent="copyToClipboard(evt, window.location.href)">Copy Link</button>
      <button
        class="button"
        style="display: none;"
        data-show="$public === 0"
        data-on:click__prevent="@post('/make-public/{{code}}')">Make Public</button>
    </div>
    <div class='variant' style="display: none;" data-show="$state === 'waiting' && $paired">
      <p>Waiting for players...</p>
    </div>
  </div>

  <div style="display: none;" data-show="$state !== 'waiting'">
    <div class="player-bar top-bar">
      <span class="player-time" data-text="$_topBar.periods.toFixed(1)"></span>
      <a
        class="player-name"
        data-attr:href="`/profile/${$_topBar.code}`"
        data-text="$_topBar.name"></a>
    </div>

    {{> _board}}

    <div class="player-bar bottom-bar">
      <a
        class="player-name"
        data-attr:href="`/profile/${$_bottomBar.code}`"
        data-text="$_bottomBar.name"></a>
      <span class="player-time" data-text="$_bottomBar.periods.toFixed(1)"></span>
    </div>
  </div>

</div>
