{{> _header}}

{{#active}}
  <div data-init="@post('/stream/{{code}}', { retry: 'always' })"></div>
  <div data-on:make-move__window="@post(`/move/{{code}}/${evt.detail.from}/${evt.detail.to}`)"></div>
  <div data-on:flag__window="@get('/check/{{code}}')"></div>
{{/active}}

<div data-signals="{ color: '{{color}}', turn: '{{turn}}', state: '{{state}}', wp: {{wp}}, bp: {{bp}}, wn: '{{wn}}', bn: '{{bn}}', result: '{{result}}', statusDismissed: false, ply: {{max_ply}}, maxPly: {{max_ply}} }">
  <div data-on:keydown__window="evt.key === 'ArrowLeft' && @get('/replay/{{code}}/' + ($ply - 1))"></div>
  <div data-on:keydown__window="evt.key === 'ArrowRight' && @get('/replay/{{code}}/' + ($ply + 1))"></div>
  <div class="game-area">

    <div class="game-status" style="display: none;" data-show="($state == 'waiting' || ($state == 'resolved' && $ply === $maxPly)) && !$statusDismissed">
      <button class="dismiss-btn" style="display: none;" data-show="$state === 'resolved'" data-on:click__prevent="$statusDismissed = true">&times;</button>
      <div style="display: none;" data-show="$state === 'resolved'" data-text="$result"></div>
      <div style="display: none;" data-show="$state === 'waiting'">
        <p>Waiting for opponent...</p>
        <button data-on:click__prevent="navigator.clipboard.writeText(window.location.href); evt.target.innerHTML = 'Copied!'; setTimeout(() => evt.target.innerHTML = 'Copy Link', 2000)">Copy Link</button>
      </div>
    </div>

    <div class="player-bar top-bar">
      <span class="player-time" data-text="($color === 'black' ? $wp : $bp).toFixed(1)"></span>
      <span class="player-name" data-text="$color === 'black' ? ($wn || 'White') : ($bn || 'Black')"></span>
    </div>

    {{> _board}}

    <div class="player-bar bottom-bar">
      <span class="player-name" data-text="$color === 'black' ? ($bn || 'Black') : ($wn || 'White')"></span>
      <span class="player-time" data-text="($color === 'black' ? $bp : $wp).toFixed(1)"></span>
    </div>

  </div>
</div>
