<div class="status-bar">

  <div style="display: none;" data-show="$state === 'resolved'" data-text="$result"></div>

  <div style="display: none;" data-show="$state === 'waiting'">Waiting for opponent...</div>

  <div style="display: none;" data-show="$state === 'playing'">
    <span data-text="$turn === 'white' ? 'White to move' : 'Black to move'"></span>
    <span class="periods">
      <span class="period-white" data-text="'⏱ ' + $wp.toFixed(1)"></span>
      <span class="period-black" data-text="'⏱ ' + $bp.toFixed(1)"></span>
    </span>
  </div>

</div>
